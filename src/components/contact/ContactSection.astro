---
import ContactForm from './ContactForm.tsx';

const contactLinks = [
  {
    label: 'Email',
    value: 'denisberroeta@gmail.com',
    href: 'mailto:denisberroeta@gmail.com',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>`,
    color: '#2B5C3F',
  },
  {
    label: 'LinkedIn',
    value: 'denis-berroeta',
    href: 'https://www.linkedin.com/in/denis-berroeta',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
    color: '#4A6FA5',
  },
  {
    label: 'GitHub',
    value: 'DenisSebastian',
    href: 'https://github.com/DenisSebastian',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>`,
    color: '#1A1917',
  },
];
---

<section id="contact" class="relative py-0 bg-[#F5F4EF]">
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse at 50% 0%, rgba(43,92,63,0.04) 0%, transparent 50%);"
  ></div>

  <div class="relative z-10" style="max-width:1280px;margin-left:auto;margin-right:auto;padding-left:clamp(2rem,5vw,5rem);padding-right:clamp(2rem,5vw,5rem);">
    <!-- Header -->
    <div class="gsap-reveal mb-3 text-center">
      <span class="font-mono text-[#2B5C3F] text-xs tracking-[0.3em] uppercase">
        06 / Contact
      </span>
    </div>
    <div class="gsap-reveal mb-3 text-center">
      <h2 class="font-display font-semibold text-4xl md:text-5xl text-[#1A1917]">
        Let's Work Together
      </h2>
    </div>
    <div class="gsap-reveal mb-8 text-center">
      <p class="text-[#6B6865] text-lg max-w-2xl mx-auto">
        Have a territorial challenge that needs AI? Let's decode it together.
      </p>
    </div>

    <!-- Two-column: Form left, Cards right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">

      <!-- Left: Form -->
      <div class="gsap-reveal rounded-2xl p-8 border border-black/7 bg-[#FDFCF9]">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-6 h-px bg-[#2B5C3F]"></span>
          <h3 class="font-mono text-[#2B5C3F] text-xs tracking-[0.2em] uppercase font-semibold">
            Get In Touch
          </h3>
        </div>
        <ContactForm client:visible />
      </div>

      <!-- Right: Contact cards -->
      <div class="gsap-reveal flex flex-col gap-4">
        <!-- Location badge -->
        <div class="flex items-center gap-3 mb-2">
          <div class="w-2 h-2 rounded-full bg-[#2B5C3F] animate-pulse"></div>
          <span class="font-mono text-[#6B6865] text-xs tracking-wider uppercase">Isla Negra, Chile — 33°26'S, 71°41'W</span>
        </div>

        {
          contactLinks.map((link) => (
            <a
              href={link.href}
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              class="group flex items-center gap-4 p-5 rounded-xl border border-black/7 bg-[#FDFCF9] hover:border-[#2B5C3F22] hover:-translate-y-1 hover:shadow-[0_4px_16px_rgba(0,0,0,0.06)] transition-all duration-300"
            >
              <div
                class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0 transition-all duration-300 group-hover:scale-110"
                style={`background: ${link.color}12; color: ${link.color};`}
                set:html={link.icon}
              />
              <div>
                <div class="text-[#6B6865] text-xs font-mono">{link.label}</div>
                <div class="text-[#1A1917] text-sm font-medium mt-0.5 group-hover:text-[#2B5C3F] transition-colors duration-200">
                  {link.value}
                </div>
              </div>
            </a>
          ))
        }
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray<HTMLElement>('#contact .gsap-reveal').forEach((el, i) => {
    gsap.to(el, {
      opacity: 1,
      y: 0,
      duration: 0.7,
      delay: i * 0.1,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 88%',
        toggleActions: 'play none none none',
      },
    });
  });
</script>
