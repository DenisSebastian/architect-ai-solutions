---
import AnimatedCounters from './AnimatedCounters.tsx';
import MiniMap from './MiniMap.tsx';
---

<section id="about" class="relative py-0 bg-[#EEEAE4]">
  <!-- Subtle topographic contour overlay -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-25">
    <svg
      width="100%"
      height="100%"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="xMidYMid slice"
    >
      <defs>
        <pattern id="topo-about" x="0" y="0" width="200" height="200" patternUnits="userSpaceOnUse">
          <ellipse cx="100" cy="100" rx="80" ry="60" fill="none" stroke="#2B5C3F" stroke-width="0.6" opacity="0.3"></ellipse>
          <ellipse cx="100" cy="100" rx="55" ry="40" fill="none" stroke="#2B5C3F" stroke-width="0.6" opacity="0.3"></ellipse>
          <ellipse cx="100" cy="100" rx="30" ry="20" fill="none" stroke="#2B5C3F" stroke-width="0.6" opacity="0.3"></ellipse>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#topo-about)"></rect>
    </svg>
  </div>

  <div class="relative z-10" style="max-width:1280px;margin-left:auto;margin-right:auto;padding-left:clamp(2rem,5vw,5rem);padding-right:clamp(2rem,5vw,5rem);">
    <!-- Section header -->
    <div class="gsap-reveal mb-8 text-center">
      <span class="font-mono text-[#2B5C3F] text-xs tracking-[0.3em] uppercase block mb-3"
        >01 / About</span
      >
      <h2 class="font-display font-semibold text-4xl md:text-5xl text-[#1A1917]">
        Who I Am
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <!-- Left: Photo + Counters -->
      <div class="flex flex-col gap-8">
        <!-- Photo -->
        <div class="gsap-reveal flex justify-center">
          <div class="relative group">
            <!-- Glow ring -->
            <div
              class="absolute -inset-2 rounded-full blur-xl bg-[#2B5C3F22] group-hover:bg-[#2B5C3F44] transition-all duration-500"
            ></div>
            <!-- Border -->
            <div
              class="absolute -inset-1 rounded-full bg-gradient-to-br from-[#2B5C3F] to-[#4E9E71] opacity-40 group-hover:opacity-70 transition-opacity duration-300"
            ></div>
            <!-- Photo container -->
            <div
              class="relative w-48 h-48 md:w-56 md:h-56 rounded-full overflow-hidden border-4 border-[#EEEAE4]"
            >
              <div
                class="w-full h-full bg-gradient-to-br from-[#2B5C3F] to-[#1A3D28] flex items-center justify-center"
              >
                <span
                  class="font-display font-bold text-5xl text-white/90 select-none"
                  >DB</span
                >
              </div>
            </div>
          </div>
        </div>

        <!-- Counters -->
        <div class="gsap-reveal">
          <AnimatedCounters client:visible />
        </div>
      </div>

      <!-- Right: Bio + Map + Socials -->
      <div class="flex flex-col gap-8">
        <div class="gsap-reveal">
          <h3 class="font-heading font-semibold text-base text-[#2B5C3F] mb-4 tracking-wider uppercase">
            AI · Territory · Intelligence
          </h3>
          <p class="text-[#6B6865] leading-relaxed mb-4">
            I architect AI solutions that decode territory. With a PhD candidate
            background in Data Science and 7+ years at CIT-UAI (Center for
            Territorial Intelligence), I bridge the gap between satellite sensors
            and policy decisions.
          </p>
          <p class="text-[#6B6865] leading-relaxed mb-4">
            I'm not a data scientist who happens to work with maps — I'm a
            <span class="text-[#1A1917] font-semibold"
              >territorial intelligence architect</span
            > who designs end-to-end AI systems that connect earth observation data
            to actionable insights for governments, organizations, and communities.
          </p>
          <p class="text-[#6B6865] leading-relaxed">
            Specializing in agentic AI for territorial problems, deep learning for change detection,
            geospatial data pipelines, and spatial analysis for public
            policy. Based in the beautiful coastal town of Isla Negra, Chile.
          </p>
        </div>

        <!-- Mini Map -->
        <div class="gsap-reveal">
          <MiniMap client:visible />
        </div>

        <!-- Social Links -->
        <div class="gsap-reveal flex flex-wrap gap-3">
          {
            [
              {
                label: 'GitHub',
                href: 'https://github.com/DenisSebastian',
              },
              {
                label: 'LinkedIn',
                href: 'https://www.linkedin.com/in/denis-berroeta',
              },
              {
                label: 'Google Scholar',
                href: 'https://scholar.google.com',
              },
              {
                label: 'ResearchGate',
                href: 'https://www.researchgate.net',
              },
            ].map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="px-4 py-2 rounded-lg border border-black/10 text-[#6B6865] text-sm font-mono hover:text-[#2B5C3F] hover:border-[#2B5C3F44] hover:-translate-y-0.5 bg-[#FDFCF9]/60 transition-all duration-200"
              >
                {s.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray<HTMLElement>('#about .gsap-reveal').forEach((el, i) => {
    gsap.to(el, {
      opacity: 1,
      y: 0,
      duration: 0.7,
      delay: i * 0.1,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 85%',
        toggleActions: 'play none none none',
      },
    });
  });
</script>
