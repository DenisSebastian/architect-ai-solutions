---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const tagColors: Record<string, string> = {
  'Deep Learning': '#C04A2E',
  'Sentinel-2': '#2B5C3F',
  PyTorch: '#C04A2E',
  'Change Detection': '#2B5C3F',
  R: '#4A6FA5',
  Python: '#4A6FA5',
  Geospatial: '#2B5C3F',
  Architecture: '#6B52A8',
  'Google Earth Engine': '#2B5C3F',
  'Remote Sensing': '#8C6D3F',
  GEE: '#2B5C3F',
};

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Blog — Denis Berroeta" description="Technical articles on AI, remote sensing, geospatial data science, and territorial intelligence.">
  <div class="min-h-screen bg-[#F5F4EF] pt-32 pb-24">
    <div class="max-w-3xl mx-auto px-6 md:px-12">

      <!-- Back link -->
      <a href="/" class="inline-flex items-center gap-2 text-[#6B6865] hover:text-[#2B5C3F] text-sm font-mono mb-10 transition-colors duration-200">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
        </svg>
        Back to Home
      </a>

      <!-- Header -->
      <div class="mb-12">
        <span class="font-mono text-[#2B5C3F] text-xs tracking-[0.3em] uppercase block mb-3">Technical Writings</span>
        <h1 class="font-display font-semibold text-4xl md:text-5xl text-[#1A1917] mb-4">Blog</h1>
        <p class="text-[#6B6865] text-lg max-w-xl">Deep dives into AI, remote sensing, geospatial data science, and territorial intelligence.</p>
      </div>

      <!-- Post list -->
      <div class="flex flex-col gap-4">
        {posts.map((post) => (
          <article class="group relative p-6 rounded-2xl border border-black/7 bg-[#FDFCF9] hover:-translate-y-1 hover:shadow-[0_4px_20px_rgba(0,0,0,0.07)] transition-all duration-300">
            <!-- Top accent on hover -->
            <div class="absolute top-0 left-0 right-0 h-0.5 rounded-t-2xl bg-[#2B5C3F] opacity-0 group-hover:opacity-100 transition-opacity duration-300" />

            <div class="flex flex-col sm:flex-row sm:items-start gap-4">
              <div class="flex-1">
                <time class="font-mono text-[#6B6865] text-xs">{formatDate(post.data.date)}</time>
                <h2 class="font-heading font-semibold text-[#1A1917] text-xl mt-2 mb-3 group-hover:text-[#2B5C3F] transition-colors duration-200 leading-snug">
                  <a href={`/blog/${post.id}`}>{post.data.title}</a>
                </h2>
                <p class="text-[#6B6865] text-sm leading-relaxed mb-4">{post.data.description}</p>
                <div class="flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <span
                      class="px-2 py-0.5 rounded text-[10px] font-mono border"
                      style={`color: ${tagColors[tag] || '#6B6865'}; border-color: ${tagColors[tag] || '#6B6865'}25; background: ${tagColors[tag] || '#6B6865'}08;`}
                    >
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              <a
                href={`/blog/${post.id}`}
                class="sm:mt-2 inline-flex items-center gap-1.5 text-[#2B5C3F] text-sm font-semibold whitespace-nowrap hover:gap-3 transition-all duration-200"
              >
                Read
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>

    </div>
  </div>
</BaseLayout>
