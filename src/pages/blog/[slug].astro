---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const tagColors: Record<string, string> = {
  'Deep Learning': '#C04A2E',
  'Sentinel-2': '#2B5C3F',
  PyTorch: '#C04A2E',
  R: '#4A6FA5',
  Python: '#4A6FA5',
  Geospatial: '#2B5C3F',
  'Google Earth Engine': '#2B5C3F',
  'Remote Sensing': '#8C6D3F',
};
---

<BaseLayout
  title={`${post.data.title} — Denis Berroeta`}
  description={post.data.description}
>
  <div class="min-h-screen bg-[#F5F4EF] pt-32 pb-24">
    <div class="max-w-3xl mx-auto px-6 md:px-12">

      <!-- Back link -->
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-[#6B6865] hover:text-[#2B5C3F] text-sm font-mono mb-10 transition-colors duration-200"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
        </svg>
        All Posts
      </a>

      <!-- Header -->
      <div class="mb-10 pb-10 border-b border-black/7">
        <div class="flex flex-wrap gap-2 mb-5">
          {post.data.tags.map((tag) => (
            <span
              class="px-2 py-0.5 rounded text-[10px] font-mono border"
              style={`color: ${tagColors[tag] || '#6B6865'}; border-color: ${tagColors[tag] || '#6B6865'}25; background: ${tagColors[tag] || '#6B6865'}08;`}
            >
              {tag}
            </span>
          ))}
        </div>
        <h1 class="font-display font-semibold text-3xl md:text-4xl text-[#1A1917] mb-5 leading-tight">
          {post.data.title}
        </h1>
        <div class="flex items-center gap-3 text-[#6B6865] text-sm font-mono">
          <span>{post.data.author}</span>
          <span class="text-black/20">·</span>
          <time>{formatDate(post.data.date)}</time>
        </div>
      </div>

      <!-- Content -->
      <div class="prose-content">
        <Content />
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .prose-content :global(h1),
  .prose-content :global(h2),
  .prose-content :global(h3) {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 600;
    color: #1A1917;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  .prose-content :global(h1) { font-size: 2rem; }
  .prose-content :global(h2) { font-size: 1.6rem; color: #2B5C3F; }
  .prose-content :global(h3) { font-size: 1.2rem; color: #1A1917; }
  .prose-content :global(p) {
    color: #4A4845;
    line-height: 1.85;
    margin-bottom: 1.25rem;
    font-size: 1rem;
  }
  .prose-content :global(strong) { color: #1A1917; font-weight: 600; }
  .prose-content :global(code) {
    font-family: 'JetBrains Mono', monospace;
    background: #EEEAE4;
    color: #2B5C3F;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
  }
  .prose-content :global(pre) {
    background: #1A1917;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 12px;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .prose-content :global(pre code) {
    background: none;
    padding: 0;
    color: #F5F4EF;
  }
  .prose-content :global(ul),
  .prose-content :global(ol) {
    color: #4A4845;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    line-height: 1.8;
  }
  .prose-content :global(li) { margin-bottom: 0.5rem; }
  .prose-content :global(a) {
    color: #2B5C3F;
    text-decoration: underline;
    text-decoration-color: rgba(43,92,63,0.3);
  }
  .prose-content :global(blockquote) {
    border-left: 3px solid #2B5C3F;
    padding-left: 1.25rem;
    color: #6B6865;
    font-style: italic;
    margin: 1.5rem 0;
  }
  .prose-content :global(hr) {
    border: none;
    border-top: 1px solid rgba(0,0,0,0.08);
    margin: 2rem 0;
  }
</style>
